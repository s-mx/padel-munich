# Copy this file to .env and fill in your values
# Never commit .env to git

# --- activity_tracker bot ---
BOT_TOKEN=your_bot_token_here

# Logging verbosity: DEBUG (local dev) | INFO (default) | WARNING (prod, quieter)
LOG_LEVEL=INFO

# Comma-separated Telegram user IDs that can run admin commands (/stats, /inactive, /top)
ADMIN_IDS=123456789,987654321

# Database URL — overridden per-service in docker-compose.yml for local dev
# For local use outside Docker: postgresql+asyncpg://padel:padel@localhost/padel
DB_URL=postgresql+asyncpg://padel:padel@db/padel

# --- scripts/seed_members.py (one-time initial scan) ---
# Get API_ID and API_HASH from https://my.telegram.org (free, takes 2 minutes)
API_ID=
API_HASH=
# Group username (e.g. @mypadelgroup) or numeric chat ID
CHAT_ID=@your_group_username
